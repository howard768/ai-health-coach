---
import Layout from '@/layouts/Layout.astro';
import Nav from '@/components/Nav.astro';
import Hero from '@/components/Hero.astro';
import SourcesStrip from '@/components/SourcesStrip.astro';
import HowItWorks from '@/components/HowItWorks.astro';
import Patterns from '@/components/Patterns.astro';
import PhoneTour from '@/components/PhoneTour.astro';
import VsChatGPT from '@/components/VsChatGPT.astro';
import Science from '@/components/Science.astro';
import FounderNote from '@/components/FounderNote.astro';
import PrivacyTrust from '@/components/PrivacyTrust.astro';
import FAQ from '@/components/FAQ.astro';
import CTA from '@/components/CTA.astro';
import Footer from '@/components/Footer.astro';

// SoftwareApplication schema for the home page (Meld = iOS HealthApplication)
const softwareAppSchema = {
  '@context': 'https://schema.org',
  '@type': 'SoftwareApplication',
  name: 'Meld',
  applicationCategory: 'HealthApplication',
  operatingSystem: 'iOS 17+',
  description:
    'Meld connects Oura, Apple Health, Peloton, Garmin, and Whoop into one coach. It finds cross-source patterns over 21+ days, cites the research, and tells you one thing to try today.',
  offers: {
    '@type': 'Offer',
    price: '0',
    priceCurrency: 'USD',
    availability: 'https://schema.org/PreOrder',
  },
  author: {
    '@type': 'Person',
    name: 'Brock Howard',
  },
};
---

<Layout
  title="Meld · Your health, synthesized"
  description="Meld pulls your Oura, Apple Health, Garmin, and Peloton into one coach. It finds patterns you would never spot, cites the research, and tells you what to do today."
  jsonLd={softwareAppSchema}
>
  <Nav slot="nav" />
  <Hero />
  <SourcesStrip />
  <HowItWorks />
  <Patterns />
  <PhoneTour />
  <VsChatGPT />
  <Science />
  <FounderNote />
  <PrivacyTrust />
  <FAQ />
  <CTA />
  <Footer slot="footer" />
</Layout>
