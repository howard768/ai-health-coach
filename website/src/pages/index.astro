---
import Layout from '@/layouts/Layout.astro';
import Nav from '@/components/Nav.astro';
import Hero from '@/components/Hero.astro';
import Problem from '@/components/Problem.astro';
import Solution from '@/components/Solution.astro';
import HowItWorks from '@/components/HowItWorks.astro';
import InsideApp from '@/components/InsideApp.astro';
import ResearchGrounded from '@/components/ResearchGrounded.astro';
import PatternDiscovery from '@/components/PatternDiscovery.astro';
import DataSources from '@/components/DataSources.astro';
import PrivacyTrust from '@/components/PrivacyTrust.astro';
import FounderNote from '@/components/FounderNote.astro';
import FAQ from '@/components/FAQ.astro';
import FinalCTA from '@/components/FinalCTA.astro';
import Footer from '@/components/Footer.astro';

// SoftwareApplication schema for the home page (Meld = iOS HealthApplication)
const softwareAppSchema = {
  '@context': 'https://schema.org',
  '@type': 'SoftwareApplication',
  name: 'Meld',
  applicationCategory: 'HealthApplication',
  operatingSystem: 'iOS 17+',
  description:
    'Meld connects Oura, Apple Health, Peloton, Garmin, and more into one synthesized view — and coaches you against it with literature-grounded insights.',
  offers: {
    '@type': 'Offer',
    price: '0',
    priceCurrency: 'USD',
    availability: 'https://schema.org/PreOrder',
  },
  author: {
    '@type': 'Person',
    name: 'Brock Howard',
  },
};
---

<Layout
  title="Meld — Your Health, Synthesized"
  description="Meld quietly connects every signal from your body — sleep, workouts, food, recovery — and tells you what matters, what it means, and what to do next. Join the waitlist."
  jsonLd={softwareAppSchema}
>
  <Nav slot="nav" />
  <Hero />
  <Problem />
  <Solution />
  <HowItWorks />
  <InsideApp />
  <ResearchGrounded />
  <PatternDiscovery />
  <DataSources />
  <PrivacyTrust />
  <FounderNote />
  <FAQ />
  <FinalCTA />
  <Footer slot="footer" />
</Layout>
