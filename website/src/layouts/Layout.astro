---
import '@/styles/global.css';

interface Props {
  title?: string;
  description?: string;
  canonical?: string;
  ogImage?: string;
  ogType?: 'website' | 'article';
  noindex?: boolean;
  /** Inject additional JSON-LD blocks for page-specific schemas (FAQ, Article, etc.) */
  jsonLd?: Record<string, unknown> | Record<string, unknown>[];
}

const {
  title = 'Meld · Your health, synthesized',
  description = 'Meld pulls your Oura, Apple Health, Garmin, and Peloton into one coach. It finds patterns you would never spot, cites the research, and tells you what to do today.',
  canonical,
  ogImage = '/og-default.png',
  ogType = 'website',
  noindex = false,
  jsonLd,
} = Astro.props;

const siteUrl = 'https://heymeld.com';
const tdAppId = import.meta.env.PUBLIC_TELEMETRYDECK_APP_ID;
const pageUrl = canonical ?? new URL(Astro.url.pathname, siteUrl).toString();
const ogImageUrl = new URL(ogImage, siteUrl).toString();

// Organization schema : site-wide
const orgSchema = {
  '@context': 'https://schema.org',
  '@type': 'Organization',
  name: 'Meld',
  url: siteUrl,
  logo: `${siteUrl}/favicon.svg`,
  description:
    'Meld is an AI health coach that reads your Oura, Apple Health, Garmin, and Peloton together. It finds cross-source patterns, cites the research, and tells you one thing to try today.',
};

// Collapse page-specific jsonLd into array for rendering
const jsonLdBlocks: Record<string, unknown>[] = [orgSchema];
if (jsonLd) {
  if (Array.isArray(jsonLd)) {
    jsonLdBlocks.push(...jsonLd);
  } else {
    jsonLdBlocks.push(jsonLd);
  }
}
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover" />
    <meta name="generator" content={Astro.generator} />
    <meta name="theme-color" content="#5438a6" />
    <meta name="color-scheme" content="light" />

    {/* --- Primary meta --- */}
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={pageUrl} />
    {noindex && <meta name="robots" content="noindex, nofollow" />}

    {/* --- OpenGraph --- */}
    <meta property="og:site_name" content="Meld" />
    <meta property="og:type" content={ogType} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={pageUrl} />
    <meta property="og:image" content={ogImageUrl} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:locale" content="en_US" />

    {/* --- Twitter --- */}
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageUrl} />

    {/* --- Favicon --- */}
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />
    <meta name="apple-mobile-web-app-title" content="Meld" />

    {/* --- Fonts: Roboto (Thin 100, Light 300, Regular 400, Medium 500, Bold 700) --- */}
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      rel="preload"
      as="style"
      href="https://fonts.googleapis.com/css2?family=Roboto:wght@100;300;400;500;700&display=swap"
    />
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Roboto:wght@100;300;400;500;700&display=swap"
    />

    {/* --- TelemetryDeck : privacy-first analytics --- */}
    {tdAppId && (
      <script
        src="https://cdn.telemetrydeck.com/websdk/telemetrydeck.min.js"
        data-app-id={tdAppId}
        defer
      ></script>
    )}

    {/* --- Structured data (JSON-LD) --- */}
    {
      jsonLdBlocks.map((block) => (
        <script type="application/ld+json" set:html={JSON.stringify(block)} />
      ))
    }
  </head>
  <body>
    <a href="#main" class="skip-link">Skip to main content</a>
    <slot name="nav" />
    <main id="main">
      <slot />
    </main>
    <slot name="footer" />

    {/* Reveal-on-scroll : progressive enhancement, zero-JS fallback = visible */}
    <script>
      if (typeof window !== 'undefined' && 'IntersectionObserver' in window) {
        const revealEls = document.querySelectorAll('.reveal');
        const io = new IntersectionObserver(
          (entries) => {
            for (const entry of entries) {
              if (entry.isIntersecting) {
                entry.target.classList.add('in');
                io.unobserve(entry.target);
              }
            }
          },
          { rootMargin: '0px 0px -10% 0px', threshold: 0.05 }
        );
        revealEls.forEach((el) => io.observe(el));
      } else {
        document.querySelectorAll('.reveal').forEach((el) => el.classList.add('in'));
      }
    </script>

    {/* TelemetryDeck instrumentation : fires custom signals for scroll depth,
        data-track click handlers, and UTM-tagged page views. No-op when
        PUBLIC_TELEMETRYDECK_APP_ID is not set. */}
    <script>
      (function () {
        interface TDShape {
          signal?: (
            name: string,
            payload?: Record<string, string>
          ) => void;
        }

        function td(): TDShape | undefined {
          return (window as unknown as { TelemetryDeck?: TDShape })
            .TelemetryDeck;
        }

        function signal(name: string, payload?: Record<string, string>) {
          try {
            td()?.signal?.(name, payload);
          } catch {
            /* no-op */
          }
        }

        // ── 1. Preserve UTM params across navigation + tag the page view ─
        const params = new URLSearchParams(window.location.search);
        const utm: Record<string, string> = {};
        for (const k of [
          'utm_source',
          'utm_medium',
          'utm_campaign',
          'utm_term',
          'utm_content',
        ]) {
          const v = params.get(k);
          if (v) utm[k] = v;
        }
        if (Object.keys(utm).length) {
          try {
            sessionStorage.setItem('meld_utm', JSON.stringify(utm));
          } catch {
            /* sessionStorage may be blocked */
          }
        }
        // Fire a single tagged page view with UTM + path so Meld Web's
        // TelemetryDeck dashboard can segment by campaign.
        const storedUtm = (() => {
          try {
            return JSON.parse(sessionStorage.getItem('meld_utm') ?? '{}');
          } catch {
            return {};
          }
        })();
        signal('PageView', {
          path: window.location.pathname,
          ...storedUtm,
        });

        // ── 2. data-track click handler ────────────────────────────────
        document.addEventListener(
          'click',
          (event) => {
            const target = event.target as HTMLElement | null;
            if (!target) return;
            const tracked = target.closest<HTMLElement>('[data-track]');
            if (!tracked) return;
            const name = tracked.getAttribute('data-track');
            if (!name) return;
            signal('Click', { target: name, path: window.location.pathname });
          },
          { passive: true }
        );

        // ── 3. Scroll depth (25/50/75/100) : fires each milestone once ──
        const milestones = [25, 50, 75, 100];
        const hit = new Set<number>();
        function checkScroll() {
          const scroll = window.scrollY;
          const vh = window.innerHeight;
          const doc = Math.max(
            document.documentElement.scrollHeight - vh,
            1
          );
          const pct = Math.round((scroll / doc) * 100);
          for (const m of milestones) {
            if (pct >= m && !hit.has(m)) {
              hit.add(m);
              signal('ScrollDepth', {
                milestone: String(m),
                path: window.location.pathname,
              });
            }
          }
        }
        let scrollRaf = 0;
        window.addEventListener(
          'scroll',
          () => {
            if (scrollRaf) return;
            scrollRaf = requestAnimationFrame(() => {
              scrollRaf = 0;
              checkScroll();
            });
          },
          { passive: true }
        );
        // Fire an initial check in case the page loaded already-scrolled
        // (e.g. anchor link).
        checkScroll();
      })();
    </script>

    <style>
      .skip-link {
        position: absolute;
        top: -40px;
        left: 8px;
        background: var(--purple-600);
        color: #fff;
        padding: var(--sp-3) var(--sp-4);
        border-radius: var(--r-md);
        z-index: 1000;
      }
      .skip-link:focus {
        top: 8px;
      }
    </style>
  </body>
</html>
