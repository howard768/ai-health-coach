---
import Mascot from './Mascot.astro';
---

<header class="nav" data-nav>
  <div class="container nav-inner">
    <a href="/" class="wordmark" aria-label="Meld home">
      <Mascot size={32} />
      <span>Meld</span>
    </a>

    <nav class="nav-links" aria-label="Primary">
      <a href="/journal">Journal</a>
      <a href="#how-it-works">How it works</a>
      <a href="#faq">FAQ</a>
    </nav>

    <a href="#waitlist" class="btn btn-primary btn-nav">Get early access</a>
  </div>
</header>

<script>
  const nav = document.querySelector<HTMLElement>('[data-nav]');
  if (nav) {
    const update = () => {
      if (window.scrollY > 16) nav.setAttribute('data-scrolled', '');
      else nav.removeAttribute('data-scrolled');
    };
    update();
    window.addEventListener('scroll', update, { passive: true });
  }
</script>

<style>
  .nav {
    position: sticky;
    top: 0;
    z-index: 100;
    background: rgba(255, 255, 255, 0.6);
    -webkit-backdrop-filter: blur(24px) saturate(180%);
    backdrop-filter: blur(24px) saturate(180%);
    border-bottom: 1px solid transparent;
    transition:
      background var(--dur-base) var(--ease-out),
      box-shadow var(--dur-base) var(--ease-out),
      border-color var(--dur-base) var(--ease-out);
  }

  .nav[data-scrolled] {
    background: rgba(255, 255, 255, 0.85);
    box-shadow: var(--shadow-nav-scrolled);
    border-bottom-color: rgba(0, 0, 0, 0.04);
  }

  .nav-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--sp-4);
    height: 72px;
  }

  @media (max-width: 600px) {
    .nav-inner {
      height: 64px;
    }
  }

  .wordmark {
    display: inline-flex;
    align-items: center;
    gap: var(--sp-2);
    color: var(--text-primary);
    font-size: 1.375rem;
    font-weight: var(--fw-light);
    letter-spacing: -0.01em;
  }

  .wordmark:hover {
    color: var(--text-primary);
  }

  .wordmark svg {
    flex-shrink: 0;
  }

  .nav-links {
    display: none;
    gap: var(--sp-8);
    font-size: var(--fs-body-sm);
  }

  .nav-links a {
    color: var(--text-secondary);
    font-weight: var(--fw-regular);
  }

  .nav-links a:hover {
    color: var(--text-primary);
  }

  @media (min-width: 768px) {
    .nav-links {
      display: flex;
    }
  }

  .btn-nav {
    min-height: 42px;
    padding-inline: var(--sp-5);
    font-size: var(--fs-body-sm);
  }

  @media (max-width: 600px) {
    .btn-nav {
      min-height: 40px;
      padding-inline: var(--sp-4);
    }
  }
</style>
