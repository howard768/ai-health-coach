---
const sources = [
  { name: 'Oura', tagline: 'Sleep, HRV, recovery' },
  { name: 'Apple Health', tagline: 'Activity, heart, body' },
  { name: 'Peloton', tagline: 'Workouts, rides, runs' },
  { name: 'Garmin', tagline: 'Steps, HR, stress' },
];
---

<section class="section sources">
  <div class="container">
    <header class="sources-header">
      <h2 class="h2">Connects to the apps you already use.</h2>
    </header>

    <ul class="sources-row" aria-label="Supported data sources">
      {
        sources.map((s) => (
          <li class="source">
            <span class="source-name">{s.name}</span>
            <span class="source-tagline">{s.tagline}</span>
          </li>
        ))
      }
      <li class="source source-more">
        <span class="source-name">+ more</span>
        <span class="source-tagline">Eight Sleep, Whoop, CGMs coming</span>
      </li>
    </ul>

    <p class="sources-note">
      Open standards. OAuth-based. You control every connection.
    </p>
  </div>
</section>

<style>
  .sources {
    background: linear-gradient(180deg, var(--bg-primary) 0%, var(--bg-secondary) 100%);
  }

  .sources-header {
    text-align: center;
    margin-bottom: var(--sp-10);
  }

  .sources-header .h2 {
    max-width: 24ch;
    margin-inline: auto;
    color: var(--text-primary);
  }

  .sources-row {
    list-style: none;
    padding: 0;
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--sp-4);
    max-width: 920px;
    margin-inline: auto;
  }

  @media (min-width: 560px) {
    .sources-row {
      grid-template-columns: 1fr 1fr;
    }
  }

  @media (min-width: 900px) {
    .sources-row {
      grid-template-columns: repeat(5, 1fr);
      gap: var(--sp-3);
    }
  }

  .source {
    background: var(--bg-primary);
    border-radius: var(--r-card);
    padding: var(--sp-5) var(--sp-4);
    box-shadow: var(--shadow-card);
    text-align: center;
    display: flex;
    flex-direction: column;
    gap: var(--sp-1);
    transition: transform var(--dur-base) var(--ease-out);
  }

  .source:hover {
    transform: translateY(-2px);
  }

  .source-name {
    font-size: 1.0625rem;
    font-weight: var(--fw-medium);
    color: var(--text-primary);
    letter-spacing: -0.005em;
  }

  .source-tagline {
    font-size: var(--fs-caption);
    color: var(--text-tertiary);
  }

  .source-more .source-name {
    color: var(--purple-600);
    font-weight: var(--fw-light);
  }

  .sources-note {
    text-align: center;
    margin-top: var(--sp-6);
    font-size: var(--fs-body-sm);
    color: var(--text-tertiary);
  }
</style>
