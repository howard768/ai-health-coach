---
/*
 * Privacy : four "Never" promises on white cards.
 */
const promises = [
  { verb: 'Never', noun: 'sold.' },
  { verb: 'Never', noun: 'rented.' },
  { verb: 'Never', noun: 'shared with advertisers.' },
  { verb: 'Never', noun: 'used to train generic AI.' },
];
---

<section id="privacy" class="privacy-section">
  <div class="container privacy-grid">
    <div class="privacy-intro">
      <p class="privacy-eyebrow reveal">
        <span class="privacy-dot" aria-hidden="true"></span>
        Privacy, with teeth
      </p>
      <h2 class="display privacy-title reveal">
        Your data is yours. Four promises we can actually write down.
      </h2>
      <p class="subhead privacy-lede reveal">
        Your health signals are the most personal data you own. We treat them
        that way. Export or delete everything in two taps.
      </p>
    </div>

    <ul class="privacy-promises">
      {promises.map((p, i) => (
        <li class="privacy-card reveal" style={`transition-delay: ${i * 80}ms;`}>
          <span class="privacy-verb">{p.verb}</span>
          <span class="privacy-noun">{p.noun}</span>
        </li>
      ))}
    </ul>
  </div>
</section>

<style>
  .privacy-section {
    padding-block: var(--section-pad-y);
  }

  .privacy-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--sp-10);
    align-items: center;
  }

  @media (min-width: 900px) {
    .privacy-grid {
      grid-template-columns: 1fr 1fr;
      gap: clamp(3rem, 6vw, 5rem);
    }
  }

  .privacy-eyebrow {
    display: inline-flex;
    align-items: center;
    gap: var(--sp-2);
    font-size: var(--fs-label);
    font-weight: var(--fw-medium);
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--green-text);
    margin-bottom: var(--sp-5);
  }

  .privacy-dot {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: currentColor;
    opacity: 0.8;
  }

  .privacy-title {
    font-size: clamp(2rem, 4vw, 2.75rem);
    margin-bottom: var(--sp-5);
  }

  .privacy-lede {
    max-width: 46ch;
  }

  .privacy-promises {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 10px;
  }

  .privacy-card {
    background: #fff;
    border: 1px solid var(--bg-tertiary);
    border-radius: 14px;
    padding: 20px 24px;
    display: flex;
    align-items: baseline;
    gap: var(--sp-4);
  }

  .privacy-verb {
    font-size: var(--fs-label);
    font-weight: var(--fw-medium);
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--green-text);
    min-width: 60px;
  }

  .privacy-noun {
    font-size: 20px;
    font-weight: var(--fw-thin);
    letter-spacing: -0.01em;
    color: var(--text-primary);
  }
</style>
