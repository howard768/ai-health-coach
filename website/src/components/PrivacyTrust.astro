---
const promises = [
  {
    title: 'Encrypted',
    body: 'In transit and at rest. Full stop.',
  },
  {
    title: 'Yours to delete',
    body: 'Export or wipe everything in one tap.',
  },
  {
    title: 'Never sold',
    body: 'Not to advertisers. Not to anyone. Ever.',
  },
  {
    title: 'OAuth-based',
    body: 'Revoke any data source from inside Meld.',
  },
  {
    title: 'Literature-grounded',
    body: 'AI can be wrong. We link every claim.',
  },
];
---

<section class="section privacy-trust">
  <div class="container">
    <div class="trust-card card-glass">
      <header class="trust-header">
        <p class="eyebrow">Your data, yours</p>
        <h2 class="h1">Health data deserves a higher bar.</h2>
        <p class="subhead">
          Meld is built with health data privacy as a first principle, not a checklist item.
        </p>
      </header>

      <ul class="promises" aria-label="Privacy promises">
        {
          promises.map((p) => (
            <li class="promise">
              <div class="check" aria-hidden="true">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                  <polyline points="20 6 9 17 4 12"></polyline>
                </svg>
              </div>
              <div class="promise-text">
                <strong>{p.title}</strong>
                <span>{p.body}</span>
              </div>
            </li>
          ))
        }
      </ul>

      <div class="trust-links">
        <a href="/privacy">Read the full Privacy Policy →</a>
        <a href="/terms">Read the Terms of Service →</a>
      </div>
    </div>
  </div>
</section>

<style>
  .privacy-trust {
    background: var(--bg-secondary);
  }

  .trust-card {
    max-width: 960px;
    margin-inline: auto;
    padding: clamp(2rem, 5vw, 3.5rem);
  }

  .trust-header {
    text-align: center;
    margin-bottom: var(--sp-10);
  }

  .trust-header .h1 {
    margin-bottom: var(--sp-4);
  }

  .trust-header .subhead {
    margin-inline: auto;
  }

  .promises {
    list-style: none;
    padding: 0;
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--sp-5);
  }

  @media (min-width: 560px) {
    .promises {
      grid-template-columns: 1fr 1fr;
    }
  }

  @media (min-width: 900px) {
    .promises {
      grid-template-columns: repeat(5, 1fr);
      gap: var(--sp-4);
    }
  }

  .promise {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: var(--sp-2);
    padding: var(--sp-4);
    background: var(--bg-primary);
    border-radius: var(--r-card);
    box-shadow: 0 1px 8px rgba(0, 0, 0, 0.03);
  }

  .check {
    width: 32px;
    height: 32px;
    background: var(--green-100);
    color: var(--green-text);
    border-radius: 50%;
    display: grid;
    place-items: center;
    flex-shrink: 0;
  }

  .promise-text {
    display: flex;
    flex-direction: column;
    gap: 2px;
  }

  .promise-text strong {
    font-size: var(--fs-body);
    font-weight: var(--fw-medium);
    color: var(--text-primary);
  }

  .promise-text span {
    font-size: var(--fs-caption);
    color: var(--text-secondary);
    line-height: var(--lh-snug);
  }

  .trust-links {
    margin-top: var(--sp-10);
    display: flex;
    flex-wrap: wrap;
    gap: var(--sp-6);
    justify-content: center;
  }

  .trust-links a {
    color: var(--purple-600);
    font-weight: var(--fw-medium);
    font-size: var(--fs-body-sm);
  }
</style>
