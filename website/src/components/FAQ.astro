---
const faqs = [
  {
    q: 'When does Meld launch?',
    a: "Meld is in active build. The iOS app is close. Waitlist members get access first. We'll email you the week we open up early access.",
  },
  {
    q: 'Is it iOS only?',
    a: "At launch, yes. iPhone first. Android and web will come later, after we've made iOS great.",
  },
  {
    q: 'How much will it cost?',
    a: "Meld will have a free tier and a paid subscription for deeper coaching and history. Pricing is not finalized. Waitlist members will get a founder's rate we won't offer again.",
  },
  {
    q: 'What data sources work today?',
    a: 'Oura, Apple Health, Peloton, and Garmin are connected in the app today. More sources — Eight Sleep, Whoop, continuous glucose monitors, electronic health records — are coming.',
  },
  {
    q: 'Can I use Meld without a wearable?',
    a: 'You can get value with just Apple Health and food logging, but the coach is dramatically better when it has sleep, HRV, and recovery data from a ring or watch.',
  },
  {
    q: 'Is Meld HIPAA compliant?',
    a: 'Meld is a consumer wellness app, not a HIPAA covered entity. We still treat your data with the same seriousness HIPAA requires. Encryption, access controls, audit logs, minimum necessary access. Full details in our Privacy Policy.',
  },
  {
    q: 'Can I delete my data?',
    a: 'Any time. Inside the app or by emailing hello@heymeld.com. We comply within 30 days.',
  },
  {
    q: 'How is this different from Oura, Whoop, or ChatGPT?',
    a: 'Oura and Whoop are excellent at one thing each — their own sensor. Neither sees food, workouts from other apps, or labs. ChatGPT is a generalist that knows nothing about your body until you feed it screenshots. Meld connects everything and coaches you against all of it, automatically.',
  },
];
---

<section class="section faq" id="faq">
  <div class="container prose">
    <header class="faq-header">
      <p class="eyebrow">Questions</p>
      <h2 class="h1">Things people ask before signing up</h2>
    </header>

    <ul class="faq-list">
      {
        faqs.map((f, i) => (
          <li>
            <details class="faq-item" open={i === 0}>
              <summary>
                <span class="q-text">{f.q}</span>
                <span class="chev" aria-hidden="true">
                  <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <polyline points="6 9 12 15 18 9"></polyline>
                  </svg>
                </span>
              </summary>
              <div class="a-body">{f.a}</div>
            </details>
          </li>
        ))
      }
    </ul>
  </div>
</section>

<script define:vars={{ faqs }}>
  // Emit FAQPage structured data. Keep in sync with the array above.
  const schema = {
    '@context': 'https://schema.org',
    '@type': 'FAQPage',
    mainEntity: faqs.map((f) => ({
      '@type': 'Question',
      name: f.q,
      acceptedAnswer: {
        '@type': 'Answer',
        text: f.a,
      },
    })),
  };
  const el = document.createElement('script');
  el.type = 'application/ld+json';
  el.textContent = JSON.stringify(schema);
  document.head.appendChild(el);
</script>

<style>
  .faq {
    background: linear-gradient(180deg, var(--bg-primary) 0%, var(--purple-50) 100%);
  }

  .faq-header {
    text-align: center;
    margin-bottom: var(--sp-10);
  }

  .faq-list {
    list-style: none;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: var(--sp-3);
  }

  .faq-item {
    background: var(--bg-primary);
    border-radius: var(--r-card);
    box-shadow: var(--shadow-card);
    overflow: hidden;
    transition: box-shadow var(--dur-base) var(--ease-out);
  }

  .faq-item[open] {
    box-shadow: var(--shadow-card-hover);
  }

  .faq-item summary {
    list-style: none;
    cursor: pointer;
    padding: var(--sp-5) var(--sp-6);
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--sp-4);
    font-size: 1.0625rem;
    font-weight: var(--fw-regular);
    color: var(--text-primary);
  }

  .faq-item summary::-webkit-details-marker {
    display: none;
  }

  .q-text {
    flex: 1;
    text-align: left;
  }

  .chev {
    display: grid;
    place-items: center;
    width: 32px;
    height: 32px;
    border-radius: 50%;
    background: var(--purple-100);
    color: var(--purple-600);
    flex-shrink: 0;
    transition: transform var(--dur-base) var(--ease-out);
  }

  .faq-item[open] .chev {
    transform: rotate(180deg);
  }

  .a-body {
    padding: 0 var(--sp-6) var(--sp-5);
    color: var(--text-secondary);
    font-weight: var(--fw-light);
    line-height: var(--lh-relaxed);
    max-width: 68ch;
  }
</style>
