---
const faqs = [
  {
    q: 'Which devices does Meld read?',
    a: "Oura, Apple Health (including Apple Watch), Garmin, Peloton, and Whoop. Plus any food logging app that writes to Apple Health, or Meld's built-in log.",
  },
  {
    q: 'Do I need an Oura ring?',
    a: 'No. One connected source is enough to start. The more sources you add, the more cross-domain patterns Meld can find.',
  },
  {
    q: 'How is this different from ChatGPT?',
    a: 'ChatGPT only knows what you paste. Meld connects directly to your devices, watches 21+ days of signal, runs real statistical tests on your data, and cites where every finding came from.',
  },
  {
    q: 'When does it ship?',
    a: 'TestFlight is open now for iOS 17+. The public App Store launch is summer 2026.',
  },
  {
    q: 'How much does it cost?',
    a: 'Free during TestFlight. Pricing for public launch will be announced before it ships.',
  },
  {
    q: 'What about Android?',
    a: 'iOS first. Android is on the roadmap once the coaching model is stable across the Apple stack.',
  },
];
---

<section id="faq" class="faq-section">
  <div class="container faq-inner">
    <header class="faq-header">
      <p class="eyebrow reveal">Frequently asked</p>
      <h2 class="display faq-title reveal">Good questions, short answers.</h2>
    </header>

    <ul class="faq-list">
      {faqs.map((f, i) => (
        <li>
          <details class="faq-item" open={i === 0}>
            <summary>
              <span class="faq-q">{f.q}</span>
              <span class="faq-plus" aria-hidden="true">+</span>
            </summary>
            <div class="faq-a">{f.a}</div>
          </details>
        </li>
      ))}
    </ul>
  </div>
</section>

<script define:vars={{ faqs }}>
  // Emit FAQPage structured data. Keep in sync with the array above.
  const schema = {
    '@context': 'https://schema.org',
    '@type': 'FAQPage',
    mainEntity: faqs.map((f) => ({
      '@type': 'Question',
      name: f.q,
      acceptedAnswer: {
        '@type': 'Answer',
        text: f.a,
      },
    })),
  };
  const el = document.createElement('script');
  el.type = 'application/ld+json';
  el.textContent = JSON.stringify(schema);
  document.head.appendChild(el);
</script>

<style>
  .faq-section {
    padding-block: var(--section-pad-y);
  }

  .faq-inner {
    max-width: 820px;
  }

  .faq-header {
    margin-bottom: var(--sp-10);
  }

  .faq-title {
    margin-top: var(--sp-4);
    font-size: clamp(2rem, 4vw, 2.75rem);
  }

  .faq-list {
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .faq-item {
    border-top: 1px solid var(--bg-tertiary);
  }

  .faq-list li:last-child .faq-item {
    border-bottom: 1px solid var(--bg-tertiary);
  }

  .faq-item summary {
    list-style: none;
    cursor: pointer;
    padding: 22px 0;
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: var(--sp-4);
  }

  .faq-item summary::-webkit-details-marker {
    display: none;
  }

  .faq-q {
    font-size: 17px;
    font-weight: var(--fw-regular);
    color: var(--text-primary);
  }

  .faq-plus {
    font-size: 22px;
    color: var(--text-tertiary);
    font-weight: 200;
    line-height: 1;
    transition: transform var(--dur-base) var(--ease-spring);
    flex-shrink: 0;
  }

  .faq-item[open] .faq-plus {
    transform: rotate(45deg);
  }

  .faq-a {
    font-size: 15px;
    font-weight: var(--fw-light);
    line-height: 1.6;
    color: var(--text-secondary);
    padding-bottom: 22px;
    max-width: 60ch;
  }
</style>
