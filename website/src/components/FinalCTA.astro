---
import WaitlistForm from './WaitlistForm.astro';
import Mascot from './Mascot.astro';
---

<section class="section final-cta">
  <div class="container">
    <div class="final-inner">
      <div class="final-mascot" aria-hidden="true">
        <Mascot size={80} />
      </div>

      <h2 class="display final-headline">Be the first to meld.</h2>
      <p class="final-subhead">One email. We'll tell you the day access opens.</p>

      <div class="final-form">
        <WaitlistForm source="final_cta" onDark={true} cta="Join the waitlist" />
      </div>
    </div>
  </div>
</section>

<style>
  .final-cta {
    background:
      radial-gradient(
        ellipse 60% 50% at 50% 0%,
        rgba(184, 168, 227, 0.25) 0%,
        rgba(184, 168, 227, 0) 70%
      ),
      linear-gradient(180deg, var(--purple-600) 0%, var(--purple-500) 100%);
    color: #fff;
    padding-block: clamp(4rem, 10vw, 7rem);
  }

  .final-inner {
    text-align: center;
    max-width: 640px;
    margin-inline: auto;
    display: flex;
    flex-direction: column;
    align-items: center;
  }

  .final-mascot {
    margin-bottom: var(--sp-5);
  }

  .final-headline {
    color: #fff;
    margin-bottom: var(--sp-4);
  }

  .final-subhead {
    color: rgba(255, 255, 255, 0.85);
    font-size: var(--fs-body-lg);
    margin-bottom: var(--sp-8);
    max-width: 28ch;
  }

  .final-form {
    width: 100%;
    display: flex;
    justify-content: center;
  }
</style>
