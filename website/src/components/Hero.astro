---
import WaitlistForm from './WaitlistForm.astro';
import Mascot from './Mascot.astro';
import InsightCardAnimated from './InsightCardAnimated.astro';
---

<section class="hero" id="waitlist">
  <div class="hero-background" aria-hidden="true"></div>
  <div class="hero-ambient" aria-hidden="true">
    <Mascot size={72} tint={false} track={false} hoverable={false} />
  </div>

  <div class="container hero-grid">
    <div class="hero-copy">
      <p class="hero-eyebrow">
        <span class="eyebrow-dot" aria-hidden="true"></span>
        Pre-launch · TestFlight open
      </p>

      <h1 class="hero-headline">
        Your body sends signals every night.
        <em>Are you reading them?</em>
      </h1>

      <p class="hero-subhead">
        Meld pulls your Oura, Apple Health, Garmin, and Peloton into one coach.
        It finds patterns you would never spot, cites the research, and tells you
        what to do today.
      </p>

      <WaitlistForm
        source="hero"
        cta="Get early access"
        finePrint="No credit card. iOS 17+. Your data stays yours."
      />
    </div>

    <div class="hero-visual" aria-hidden="true">
      <InsightCardAnimated />
    </div>
  </div>
</section>

<style>
  .hero {
    position: relative;
    padding-block: clamp(2.5rem, 6vw, 5rem) clamp(3rem, 8vw, 7rem);
    overflow: hidden;
  }

  .hero-background {
    position: absolute;
    inset: 0;
    background: var(--hero-gradient);
    z-index: -1;
  }

  /* Ambient background mascot floating slowly. */
  .hero-ambient {
    position: absolute;
    top: 14%;
    left: 3%;
    opacity: 0.18;
    animation: hero-float 8s ease-in-out infinite;
    pointer-events: none;
    z-index: 0;
  }

  @keyframes hero-float {
    0%, 100% { transform: translateY(0) rotate(0deg); }
    50%      { transform: translateY(-10px) rotate(-2deg); }
  }

  @media (prefers-reduced-motion: reduce) {
    .hero-ambient { animation: none; }
  }

  @media (max-width: 600px) {
    .hero-ambient { display: none; }
  }

  .hero-grid {
    position: relative;
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--sp-10);
    align-items: center;
    z-index: 1;
  }

  @media (min-width: 980px) {
    .hero-grid {
      grid-template-columns: 1.15fr 1fr;
      gap: clamp(2rem, 6vw, 5rem);
    }
  }

  .hero-copy {
    max-width: 620px;
  }

  .hero-eyebrow {
    display: inline-flex;
    align-items: center;
    gap: var(--sp-2);
    font-size: var(--fs-label);
    font-weight: var(--fw-medium);
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--purple-600);
    margin-bottom: var(--sp-5);
  }

  .eyebrow-dot {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: currentColor;
    opacity: 0.8;
  }

  .hero-headline {
    font-family: var(--font-family);
    font-size: clamp(2.5rem, 6vw, 4.25rem);
    font-weight: var(--fw-thin);
    line-height: 1.02;
    letter-spacing: -0.028em;
    color: var(--text-primary);
    margin-bottom: var(--sp-5);
    text-wrap: balance;
  }

  .hero-headline em {
    font-style: italic;
    color: var(--purple-600);
    font-weight: inherit;
  }

  .hero-subhead {
    font-size: var(--fs-body-lg);
    font-weight: var(--fw-light);
    line-height: 1.6;
    color: var(--text-secondary);
    max-width: 48ch;
    margin-bottom: var(--sp-8);
  }

  .hero-visual {
    position: relative;
    min-height: 0;
  }

  @media (max-width: 600px) {
    .hero-subhead {
      font-size: var(--fs-body);
    }
  }
</style>
