---
/*
 * Hero right-column animation.
 *
 * Cycle (~15s):
 *   0. hidden (600ms)
 *   1. 3 source badges fade in staggered (1.4s)
 *   2. dotted SVG lines draw themselves + travel dots run (1.2s)
 *   3. insight text types character by character (~6s)
 *   4. metric tiles fade in and numbers count up, holds 5s, restart
 *
 * Under prefers-reduced-motion: renders the final state, no loop.
 */
import Mascot from './Mascot.astro';

type Source = { id: string; top: number; left: number; label: string; sub: string; initial: string; color: string };

const sources: Source[] = [
  { id: 'oura',  top: 0,   left: 0,   label: 'Oura',         sub: '21 nights',   initial: 'O', color: '#000000' },
  { id: 'apple', top: 52,  left: 100, label: 'Apple Health', sub: 'HRV · 68ms',  initial: '♥', color: '#ff3b30' },
  { id: 'food',  top: 130, left: 0,   label: 'Food log',     sub: '287 entries', initial: '◌', color: 'var(--green-500)' },
];

// Bezier connector from the badge's right edge to the insight card's left edge
// inside the 480×480 SVG viewBox.
function bezier(s: Source) {
  const x1 = s.left + 200;
  const y1 = s.top + 20;
  const x2 = 290;
  const y2 = 175;
  return `M ${x1} ${y1} C ${x1 + 40} ${y1}, ${x2 - 40} ${y2}, ${x2} ${y2}`;
}
---

<div class="insight-card-animated" data-step="4" aria-hidden="true">
  {sources.map((s, i) => (
    <div class={`source-badge source-badge-${i}`} style={`top: ${s.top}px; left: ${s.left}px;`}>
      <div class="source-tile" style={`color: ${s.color};`}>{s.initial}</div>
      <div class="source-meta">
        <div class="source-label">{s.label}</div>
        <div class="source-sub">{s.sub}</div>
      </div>
    </div>
  ))}

  <svg class="connectors" viewBox="0 0 480 480" preserveAspectRatio="none" aria-hidden="true">
    {sources.map((s, i) => (
      <path class={`line line-${i}`} d={bezier(s)} fill="none" stroke="var(--purple-300)" stroke-width="1.5" stroke-dasharray="3 4" />
    ))}
    {sources.map((s, i) => (
      <circle class={`travel-dot travel-dot-${i}`} r="3" fill="var(--purple-500)">
        <animateMotion dur="1.6s" repeatCount="indefinite" begin={`${i * 0.3}s`} path={bezier(s)} />
      </circle>
    ))}
  </svg>

  <div class="insight-body">
    <div class="insight-head">
      <Mascot size={40} state="thinking" track={false} hoverable={false} />
      <div class="insight-head-meta">
        <div class="insight-head-name">Meld</div>
        <div class="insight-head-sub">
          <span class="live-dot"></span>
          Synced 2 min ago
        </div>
      </div>
      <div class="insight-head-badge">Pattern found</div>
    </div>

    <div class="insight-body-text">
      <div class="typer-wrap">
        <span class="typer">Your <strong>deep sleep</strong> goes up <strong>22%</strong> on days you eat more <strong>protein</strong>. <strong>Lunch</strong> matters more than <strong>dinner</strong> here.</span><span class="typer-cursor" aria-hidden="true"></span>
      </div>
      <div class="typer-source">From 21 nights of Oura sleep + your food log.</div>
    </div>

    <div class="metrics">
      <div class="metric">
        <div class="metric-label">Deep sleep</div>
        <div class="metric-value-row">
          <span class="metric-value-prefix">+</span><span class="metric-value" data-target="42">42</span><span class="metric-value-unit">m</span>
        </div>
        <div class="metric-trend">vs your baseline</div>
      </div>
      <div class="metric">
        <div class="metric-label">HRV</div>
        <div class="metric-value-row">
          <span class="metric-value" data-target="68">68</span><span class="metric-value-unit">ms</span>
        </div>
        <div class="metric-trend">top 15% this month</div>
      </div>
    </div>
  </div>
</div>

<script>
  const root = document.querySelector<HTMLElement>('.insight-card-animated');
  if (root) {
    const reduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
    const typer = root.querySelector<HTMLElement>('.typer');
    const metricEls = root.querySelectorAll<HTMLElement>('.metric-value');
    const text =
      'Your deep sleep goes up 22% on days you eat more protein. Lunch matters more than dinner here.';
    const highlight = (s: string) =>
      s.replace(
        /(\d+%|\bprotein\b|\blunch\b|\bdinner\b|\bdeep sleep\b)/gi,
        '<strong>$1</strong>',
      );

    const setFinal = () => {
      root.setAttribute('data-step', '4');
      if (typer) typer.innerHTML = highlight(text);
      metricEls.forEach((el) => {
        const target = el.getAttribute('data-target') ?? '0';
        el.textContent = target;
      });
    };

    if (reduced) {
      setFinal();
    } else {
      const wait = (ms: number) => new Promise<void>((r) => window.setTimeout(r, ms));
      const countTo = (el: HTMLElement, target: number, dur: number) => {
        const start = performance.now();
        const tick = (now: number) => {
          const t = Math.min(1, (now - start) / dur);
          const eased = 1 - Math.pow(1 - t, 3);
          el.textContent = String(Math.round(target * eased));
          if (t < 1) requestAnimationFrame(tick);
        };
        requestAnimationFrame(tick);
      };

      let cancelled = false;
      const cycle = async () => {
        while (!cancelled) {
          root.setAttribute('data-step', '0');
          if (typer) typer.innerHTML = '';
          metricEls.forEach((el) => (el.textContent = '0'));
          await wait(600);
          if (cancelled) return;

          root.setAttribute('data-step', '1');
          await wait(1400);
          if (cancelled) return;

          root.setAttribute('data-step', '2');
          await wait(1200);
          if (cancelled) return;

          root.setAttribute('data-step', '3');
          for (let i = 1; i <= text.length; i++) {
            if (cancelled) return;
            if (typer) typer.innerHTML = highlight(text.slice(0, i));
            await wait(18);
          }

          root.setAttribute('data-step', '4');
          metricEls.forEach((el) => {
            const target = parseInt(el.getAttribute('data-target') ?? '0', 10);
            countTo(el, target, 900);
          });
          await wait(5000);
        }
      };

      // Start when scrolled into view (once). Saves battery when off-screen.
      const start = () => {
        if (root.dataset.started) return;
        root.dataset.started = '1';
        cycle();
      };
      if ('IntersectionObserver' in window) {
        const io = new IntersectionObserver(
          (entries) => {
            for (const entry of entries) {
              if (entry.isIntersecting) {
                start();
                io.disconnect();
              }
            }
          },
          { threshold: 0.1 },
        );
        io.observe(root);
      } else {
        start();
      }

      // Render final state immediately as a safety net (in case IO misses + for
      // the brief moment before first cycle runs).
      setFinal();
    }
  }
</script>

<style>
  .insight-card-animated {
    position: relative;
    width: 100%;
    max-width: 480px;
    height: 480px;
    margin-left: auto;
  }

  /* ---- Source badges ---- */
  .source-badge {
    position: absolute;
    z-index: 2;
    display: flex;
    align-items: center;
    gap: 10px;
    background: #fff;
    border-radius: 12px;
    padding: 10px 14px 10px 10px;
    box-shadow: var(--shadow-card);
    border: 1px solid rgba(0, 0, 0, 0.03);
    opacity: 0;
    transform: translateX(-16px);
    transition:
      opacity 600ms var(--ease-out),
      transform 600ms var(--ease-out);
  }
  .source-badge-0 { transition-delay: 0ms; }
  .source-badge-1 { transition-delay: 180ms; }
  .source-badge-2 { transition-delay: 360ms; }

  .insight-card-animated[data-step='1'] .source-badge,
  .insight-card-animated[data-step='2'] .source-badge,
  .insight-card-animated[data-step='3'] .source-badge,
  .insight-card-animated[data-step='4'] .source-badge {
    opacity: 1;
    transform: translateX(0);
  }

  .source-tile {
    width: 28px;
    height: 28px;
    border-radius: 8px;
    background: #fff;
    border: 1px solid var(--bg-tertiary);
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 13px;
    font-weight: 600;
    box-shadow: var(--shadow-low);
    flex-shrink: 0;
  }

  .source-label {
    font-size: 13px;
    font-weight: var(--fw-medium);
    color: var(--text-primary);
    line-height: 1;
  }

  .source-sub {
    font-size: 10px;
    font-weight: var(--fw-light);
    color: var(--text-tertiary);
    margin-top: 3px;
  }

  /* ---- Connectors ---- */
  .connectors {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    pointer-events: none;
    z-index: 1;
    overflow: visible;
  }

  .line {
    stroke-dashoffset: 200;
    opacity: 0;
    transition:
      stroke-dashoffset 900ms var(--ease-out),
      opacity 500ms ease;
  }
  .line-0 { transition-delay: 0ms; }
  .line-1 { transition-delay: 150ms; }
  .line-2 { transition-delay: 300ms; }

  .insight-card-animated[data-step='2'] .line,
  .insight-card-animated[data-step='3'] .line,
  .insight-card-animated[data-step='4'] .line {
    stroke-dashoffset: 0;
    opacity: 0.7;
  }

  .travel-dot {
    opacity: 0;
    transition: opacity 200ms ease;
  }
  .insight-card-animated[data-step='2'] .travel-dot,
  .insight-card-animated[data-step='3'] .travel-dot {
    opacity: 1;
  }

  /* ---- Insight body ---- */
  .insight-body {
    position: absolute;
    top: 40px;
    right: 0;
    width: 360px;
    max-width: 78%;
    z-index: 3;
    background: #fff;
    border-radius: 24px;
    padding: 22px;
    box-shadow: var(--shadow-card);
    opacity: 0;
    transform: translateY(20px) scale(0.98);
    transition:
      opacity 600ms var(--ease-out),
      transform 600ms var(--ease-out);
  }

  .insight-card-animated[data-step='1'] .insight-body,
  .insight-card-animated[data-step='2'] .insight-body,
  .insight-card-animated[data-step='3'] .insight-body,
  .insight-card-animated[data-step='4'] .insight-body {
    opacity: 1;
    transform: translateY(0) scale(1);
  }

  .insight-head {
    display: flex;
    align-items: center;
    gap: 12px;
    margin-bottom: 16px;
  }

  .insight-head-meta {
    flex: 1;
  }

  .insight-head-name {
    font-size: 14px;
    font-weight: var(--fw-medium);
    color: var(--text-primary);
  }

  .insight-head-sub {
    font-size: 11px;
    font-weight: var(--fw-light);
    color: var(--green-text);
    display: flex;
    align-items: center;
    gap: 4px;
    margin-top: 2px;
  }

  .live-dot {
    width: 5px;
    height: 5px;
    border-radius: 50%;
    background: var(--green-500);
    display: inline-block;
  }

  .insight-head-badge {
    font-size: 10px;
    font-weight: var(--fw-medium);
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--purple-600);
  }

  .insight-body-text {
    background: var(--purple-100);
    border-radius: 16px;
    padding: 18px;
    min-height: 128px;
  }

  .typer-wrap {
    font-size: 15px;
    font-weight: var(--fw-light);
    line-height: 1.55;
    color: var(--text-primary);
  }

  .typer strong {
    font-weight: var(--fw-medium);
    color: var(--purple-600);
  }

  .typer-cursor {
    display: none;
    width: 2px;
    height: 16px;
    background: var(--purple-600);
    margin-left: 2px;
    vertical-align: text-bottom;
    animation: cursor-blink 0.8s steps(2) infinite;
  }

  .insight-card-animated[data-step='3'] .typer-cursor {
    display: inline-block;
  }

  @keyframes cursor-blink {
    50% { opacity: 0; }
  }

  .typer-source {
    margin-top: 12px;
    font-size: 11px;
    color: var(--text-tertiary);
    font-style: italic;
    opacity: 0;
    transition: opacity 400ms;
  }

  .insight-card-animated[data-step='4'] .typer-source {
    opacity: 1;
  }

  .metrics {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 10px;
    margin-top: 14px;
    opacity: 0;
    transform: translateY(8px);
    transition:
      opacity 500ms var(--ease-out) 200ms,
      transform 500ms var(--ease-out) 200ms;
  }

  .insight-card-animated[data-step='4'] .metrics {
    opacity: 1;
    transform: translateY(0);
  }

  .metric {
    background: var(--bg-secondary);
    border-radius: 12px;
    padding: 12px;
  }

  .metric-label {
    font-size: 10px;
    font-weight: var(--fw-medium);
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--text-tertiary);
    margin-bottom: 6px;
  }

  .metric-value-row {
    display: flex;
    align-items: baseline;
    color: var(--text-primary);
  }

  .metric-value-prefix,
  .metric-value {
    font-size: 22px;
    font-weight: var(--fw-light);
    line-height: 1;
  }

  .metric-value-unit {
    font-size: 11px;
    color: var(--text-secondary);
    margin-left: 2px;
  }

  .metric-trend {
    font-size: 10px;
    font-weight: var(--fw-regular);
    margin-top: 5px;
    color: var(--green-text);
  }

  @media (max-width: 600px) {
    .insight-card-animated {
      height: 420px;
      max-width: 100%;
    }
    .connectors {
      display: none;
    }
    .source-badge-0 { top: 0;   left: 0; }
    .source-badge-1 { top: 30px; left: auto; right: 20%; }
    .source-badge-2 { top: 70px; left: 0; }
    .insight-body {
      top: 140px;
      width: 100%;
      max-width: 100%;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .source-badge,
    .insight-body,
    .metrics,
    .line,
    .typer-source {
      opacity: 1 !important;
      transform: none !important;
      stroke-dashoffset: 0 !important;
    }
    .typer-cursor {
      display: none !important;
    }
  }
</style>
