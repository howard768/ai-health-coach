# Meld Backend — Environment Variables
# Copy to .env and fill in real values

# Database
DATABASE_URL=postgresql+asyncpg://meld:meld_dev_password@localhost:5432/meld

# Anthropic (Claude API)
ANTHROPIC_API_KEY=sk-ant-api03-...

# Oura Ring API
OURA_CLIENT_ID=e2e9838f-15c7-450c-bd4d-8d114b367703
OURA_CLIENT_SECRET=your_oura_secret_here
OURA_REDIRECT_URI=http://localhost:8000/api/auth/oura/callback

# App Config
APP_ENV=development
APP_SECRET_KEY=change-me-in-production

# ── Production-only secrets (Apple Push + Sign in with Apple) ──
#
# Not set in dev. Live in Railway env vars in production. Listed here for
# onboarding reference only — DO NOT commit real values.
#
# WARNING: Multi-line PEM private keys (APNS_KEY_CONTENT, SIWA_KEY_CONTENT)
# CANNOT be set via Railway's variables-page UI. The UI silently strips
# newlines on paste, producing a single-line PEM that fails parsing with
# `cryptography.exceptions.InvalidKey: MalformedFraming` at startup.
#
# Caused two production incidents in 2026-04. Use one of these instead:
#
#   1. Railway GraphQL `variableUpsert` mutation (preferred, scriptable):
#
#        PAYLOAD=$(jq -n --rawfile pem ./AuthKey_XXXXXXXXXX.p8 '{
#          query: "mutation VarUpsert($input: VariableUpsertInput!) { variableUpsert(input: $input) }",
#          variables: { input: {
#            projectId: "...",
#            environmentId: "...",
#            serviceId: "...",
#            name: "APNS_KEY_CONTENT",
#            value: $pem
#          } }
#        }')
#        curl -X POST https://backboard.railway.com/graphql/v2 \
#          -H "Project-Access-Token: $RAILWAY_TOKEN" \
#          -H "Content-Type: application/json" \
#          -d "$PAYLOAD"
#
#   2. Railway CLI: `railway variables --set "APNS_KEY_CONTENT=$(cat key.p8)"`
#
# APNS (push notifications)
# APNS_KEY_CONTENT=<full .p8 contents incl. BEGIN/END markers, real newlines>
# APNS_KEY_ID=<10-char Apple-issued Key ID, e.g. RW83ZSW6LC>
# APNS_TEAM_ID=<10-char Apple Team ID>
# APNS_BUNDLE_ID=com.heymeld.app
# APNS_ENVIRONMENT=production  # or "sandbox" for TestFlight/dev

# SIWA (Sign in with Apple — optional; required for account-deletion webhook)
# SIWA_KEY_CONTENT=<full .p8 contents, same format constraints as APNs>
# SIWA_KEY_ID=<10-char Apple-issued Key ID for SIWA>
# APPLE_TEAM_ID=<same as APNS_TEAM_ID>
# APPLE_BUNDLE_ID=com.heymeld.app
